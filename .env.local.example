# Sanity CMS
# Get from: https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=
SANITY_WEBHOOK_SECRET=

# Cloudinary
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email sending)
# Get from: https://resend.com/api-keys
# RESEND_FROM_EMAIL must be from a domain verified in your Resend account
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@healths.ng
RESEND_TEAM_EMAIL=hello@healths.ng

# Brevo / Sendinblue (newsletter)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_LIST_ID=

# Algolia (search)
# Get from: https://www.algolia.com/account/api-keys
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NAME=healths_articles

# Upstash Redis (caching)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Analytics 4
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Keystatic CMS (GitHub storage for production editor)
# Create a GitHub OAuth App at github.com/settings/developers
# Callback URL: https://healths.ng/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# App Settings
NEXT_PUBLIC_SITE_URL=https://healths.ng
NEXT_PUBLIC_SITE_NAME=Healths.ng Media Limited
